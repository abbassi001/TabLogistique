{% extends 'base.html.twig' %}

{% block title %}Modifier le Département{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 py-8 max-w-4xl">
        <div class="mb-6 border-l-4 border-blue-600 pl-4 flex justify-between items-center">
            <h1 class="text-3xl font-bold text-gray-800">Modifier le Département</h1>
            <div>
                <a href="{{ path('app_departement_index') }}" class="px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-md hover:bg-gray-200 transition-all flex items-center">
                    <i class="fas fa-arrow-left mr-2"></i> Retour à la liste
                </a>
            </div>
        </div>
        
        <div class="bg-white rounded-lg shadow-lg p-6 mb-6 transition-all hover:shadow-xl border border-gray-100">
            <div class="mb-4 pb-3 border-b border-gray-100">
                <h2 class="text-xl font-semibold text-gray-700">Informations du département</h2>
                <p class="text-sm text-gray-500">Tous les champs marqués d'un * sont obligatoires</p>
            </div>
            
            {{ include('departement/_form.html.twig', {'button_label': 'Enregistrer les modifications', 'button_class': 'bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2.5 rounded-md transition-colors'}) }}
        </div>
        
        <div class="flex items-center justify-between mt-8">
            <div class="space-x-2">
                <a href="{{ path('app_departement_index') }}" class="px-5 py-2.5 bg-gray-600 text-white font-medium rounded-md hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-colors inline-flex items-center">
                    <i class="fas fa-list mr-2"></i> Voir tous les départements
                </a>
                
                <a href="{{ path('app_departement_new') }}" class="px-5 py-2.5 bg-green-600 text-white font-medium rounded-md hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors inline-flex items-center">
                    <i class="fas fa-plus mr-2"></i> Créer nouveau
                </a>
            </div>
            
            <div class="delete-container">
                {{ include('departement/_delete_form.html.twig', {
                    'button_class': 'px-5 py-2.5 bg-red-600 text-white font-medium rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors inline-flex items-center'
                }) }}
            </div>
        </div>
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .delete-container button {
            display: inline-flex;
            align-items: center;
        }
        
        .delete-container button:before {
            content: "\f2ed";
            font-family: "Font Awesome 5 Free";
            font-weight: 900;
            margin-right: 0.5rem;
        }
        
        .delete-container button:hover {
            animation: shake 0.5s;
        }
        
        @keyframes shake {
            0% { transform: translateX(0); }
            20% { transform: translateX(-2px); }
            40% { transform: translateX(2px); }
            60% { transform: translateX(-2px); }
            80% { transform: translateX(2px); }
            100% { transform: translateX(0); }
        }
    </style>
{% endblock %}