{% extends 'base.html.twig' %}

{% block title %}Détails du Département - TAB Logistique{% endblock %}

{% block body %}
<div class="container-fluid p-4">
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h1 class="h3 mb-0 text-gray-800">
                <i class="fas fa-building me-2 text-primary"></i>Détails du Département
            </h1>
            <a href="{{ path('app_departement_index') }}" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Retour à la liste
            </a>
        </div>
        
        <div class="card-body">
            <!-- Department Information Section -->
            <div class="row mb-4">
                <div class="col-md-12">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered">
                            <tbody>
                                <tr>
                                    <th class="bg-light" style="width: 200px;">ID</th>
                                    <td>{{ departement.id }}</td>
                                </tr>
                                <tr>
                                    <th class="bg-light">Nom du département</th>
                                    <td class="fw-medium">{{ departement.nomDepartemnt }}</td>
                                </tr>
                                <tr>
                                    <th class="bg-light align-text-top">Description</th>
                                    <td>
                                        {% if departement.description %}
                                            <div class="text-pre-wrap">{{ departement.description }}</div>
                                        {% else %}
                                            <span class="text-muted fst-italic">Aucune description</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <th class="bg-light">Date de création</th>
                                    <td>{{ departement.dateCreation ? departement.dateCreation|date('d/m/Y H:i') : 'N/A' }}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            
            <!-- Related Entities Section (if applicable) -->
            {% if departement.employes is defined and departement.employes|length > 0 %}
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="fas fa-users me-2"></i>Employés dans ce département</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Nom</th>
                                        <th>Prénom</th>
                                        <th>Email</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for employe in departement.employes %}
                                        <tr>
                                            <td>{{ employe.id }}</td>
                                            <td>{{ employe.nom }}</td>
                                            <td>{{ employe.prenom }}</td>
                                            <td>{{ employe.email }}</td>
                                            <td>
                                                <a href="{{ path('app_employe_show', {'id': employe.id}) }}" class="btn btn-sm btn-info">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
